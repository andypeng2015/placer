feature candidate from "placer" {
    value: string
    context: string
    length: number
    entropy: number
    recoveredBy: string
    placeholder: bool
}

outcome Secret {
    class: string
    confidence: number
}

rule AWSAccessKey priority 1 {
    when {
        candidate.value matches "^(A3T[A-Z0-9]|AKIA|ASIA)[A-Z0-9]{16}$"
    }
    then Secret {
        class: "aws_access_key",
        confidence: 0.98,
    }
}

rule GitHubToken priority 2 {
    when {
        candidate.value matches "^gh[pousr]_[A-Za-z0-9_]{36,255}$"
    }
    then Secret {
        class: "github_token",
        confidence: 0.95,
    }
}

rule StripeSecretKey priority 3 {
    when {
        candidate.value matches "^sk_(test|live)_[0-9A-Za-z]{16,}$"
    }
    then Secret {
        class: "stripe_secret_key",
        confidence: 0.95,
    }
}

rule GoogleAPIKey priority 4 {
    when {
        candidate.value matches "^AIza[0-9A-Za-z_-]{35}$"
    }
    then Secret {
        class: "google_api_key",
        confidence: 0.93,
    }
}

rule SlackToken priority 5 {
    when {
        candidate.value matches "^xox[baprs]-[0-9A-Za-z-]{20,}$"
    }
    then Secret {
        class: "slack_token",
        confidence: 0.92,
    }
}

rule JWT priority 6 {
    when {
        candidate.value matches "^eyJ[A-Za-z0-9_-]{10,}[.][A-Za-z0-9_-]{10,}[.][A-Za-z0-9_-]{8,}$"
    }
    then Secret {
        class: "jwt",
        confidence: 0.82,
    }
}

rule AnthropicKey priority 7 {
    when {
        candidate.value matches "^sk-ant-[A-Za-z0-9_-]{20,}$"
    }
    then Secret {
        class: "anthropic_api_key",
        confidence: 0.95,
    }
}

rule OpenAIKey priority 8 {
    when {
        candidate.value matches "^sk-(proj-|svcacct-|admin-)?[A-Za-z0-9]{20,}$"
    }
    then Secret {
        class: "openai_api_key",
        confidence: 0.92,
    }
}

rule GitLabPAT priority 9 {
    when {
        candidate.value matches "^glpat-[A-Za-z0-9_-]{20,}$"
    }
    then Secret {
        class: "gitlab_pat",
        confidence: 0.95,
    }
}

rule TwilioAPIKey priority 10 {
    when {
        candidate.value matches "^SK[0-9a-f]{32}$"
    }
    then Secret {
        class: "twilio_api_key",
        confidence: 0.90,
    }
}

rule SendGridKey priority 11 {
    when {
        candidate.value matches "^SG[.][A-Za-z0-9_-]{22}[.][A-Za-z0-9_-]{43,}$"
    }
    then Secret {
        class: "sendgrid_api_key",
        confidence: 0.95,
    }
}

rule NpmToken priority 12 {
    when {
        candidate.value matches "^npm_[A-Za-z0-9]{36}$"
    }
    then Secret {
        class: "npm_token",
        confidence: 0.95,
    }
}

rule GitHubFineGrainedPAT priority 13 {
    when {
        candidate.value matches "^github_pat_[A-Za-z0-9_]{82}$"
    }
    then Secret {
        class: "github_fine_grained_pat",
        confidence: 0.95,
    }
}

rule ContextualHighEntropy priority 20 {
    when {
        candidate.length >= 24
        and candidate.entropy >= 4.0
        and not candidate.placeholder
        and candidate.context matches "(?i)(api[_-]?key|secret|token|passwd|password|bearer|authorization)"
    }
    then Secret {
        class: "generic_high_entropy",
        confidence: 0.65,
    }
}

rule GenericHighEntropy priority 21 {
    when {
        candidate.length >= 24
        and candidate.entropy >= 4.0
        and not candidate.placeholder
    }
    then Secret {
        class: "generic_high_entropy",
        confidence: 0.45,
    }
}
