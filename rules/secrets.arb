feature candidate from "placer" {
    value: string
    context: string
    length: number
    entropy: number
    recoveredBy: string
    placeholder: bool
}

outcome Secret {
    class: string
    confidence: number
}

rule AWSAccessKey priority 1 {
    when {
        candidate.value matches "^(A3T[A-Z0-9]|AKIA|ASIA)[A-Z0-9]{16}$"
    }
    then Secret {
        class: "aws_access_key",
        confidence: 0.98,
    }
}

rule GitHubToken priority 2 {
    when {
        candidate.value matches "^gh[pousr]_[A-Za-z0-9_]{36,255}$"
    }
    then Secret {
        class: "github_token",
        confidence: 0.95,
    }
}

rule StripeSecretKey priority 3 {
    when {
        candidate.value matches "^sk_(test|live)_[0-9A-Za-z]{16,}$"
    }
    then Secret {
        class: "stripe_secret_key",
        confidence: 0.95,
    }
}

rule GoogleAPIKey priority 4 {
    when {
        candidate.value matches "^AIza[0-9A-Za-z_-]{35}$"
    }
    then Secret {
        class: "google_api_key",
        confidence: 0.93,
    }
}

rule SlackToken priority 5 {
    when {
        candidate.value matches "^xox[baprs]-[0-9A-Za-z-]{20,}$"
    }
    then Secret {
        class: "slack_token",
        confidence: 0.92,
    }
}

rule JWT priority 6 {
    when {
        candidate.value matches "^eyJ[A-Za-z0-9_-]{10,}[.][A-Za-z0-9_-]{10,}[.][A-Za-z0-9_-]{8,}$"
    }
    then Secret {
        class: "jwt",
        confidence: 0.82,
    }
}

rule ContextualHighEntropy priority 20 {
    when {
        candidate.length >= 24
        and candidate.entropy >= 4.0
        and not candidate.placeholder
        and candidate.context matches "(?i)(api[_-]?key|secret|token|passwd|password|bearer|authorization)"
    }
    then Secret {
        class: "generic_high_entropy",
        confidence: 0.65,
    }
}

rule GenericHighEntropy priority 21 {
    when {
        candidate.length >= 24
        and candidate.entropy >= 4.0
        and not candidate.placeholder
    }
    then Secret {
        class: "generic_high_entropy",
        confidence: 0.45,
    }
}
